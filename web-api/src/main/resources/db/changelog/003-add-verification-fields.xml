<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="003-add-verification-fields" author="salwita-team">
        
        <!-- Add verification fields to activities table -->
        <addColumn tableName="activities">
            <column name="actual_start_date" type="TIMESTAMP"/>
            <column name="actual_end_date" type="TIMESTAMP"/>
            <column name="verified_at" type="TIMESTAMP"/>
            <column name="verified_by_user_id" type="BIGINT"/>
        </addColumn>

        <!-- Add foreign key constraint for activities verified_by_user_id -->
        <addForeignKeyConstraint
            baseTableName="activities"
            baseColumnNames="verified_by_user_id"
            referencedTableName="users"
            referencedColumnNames="id"
            constraintName="fk_activities_verified_by_user"/>

    </changeSet>

</databaseChangeLog>